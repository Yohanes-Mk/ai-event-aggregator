DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aggregator
OPENAI_API_KEY=sk-...
PIPELINE_CONFIG_VERSION=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aggregator

# Optional: Webshare rotating residential proxy for YouTube transcripts
# Leave blank to use direct requests (may be IP-blocked on cloud/VPS)
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Gmail SMTP — for sending digest emails
# Use a Gmail App Password (not your account password):
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_SENDER=you@gmail.com
GMAIL_RECIPIENT=recipient@gmail.com
GMAIL_APP_PASSWORD=
